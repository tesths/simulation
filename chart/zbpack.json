{
  "$schema": "https://schema.zeabur.com/zbpack.schema.json",
  "python": {
    "version": "3.11",
    "package_manager": "pip"
  },
  "install_command": "python -m pip install -r requirements.txt",
  "start_command": "uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8080} --workers 1 --proxy-headers --forwarded-allow-ips='*'"
}
